
@article{aamor_ap16,
  title = {Second-{{Order Nédélec Curl}}-{{Conforming Prismatic Element}} for {{Computational Electromagnetics}}},
  author = {Amor-Martin, Adrian and Garcia-Castillo, Luis E. and Garcia-Donoro, Daniel},
  date = {2016},
  journaltitle = {IEEE Transactions on Antennas and Propagation},
  volume = {64},
  pages = {4384--4395},
  publisher = {{IEEE}},
  issn = {1558-2221},
  doi = {10.1109/TAP.2016.2597640},
  abstract = {A systematic approach to obtaining mixed-order curl-conforming basis functions for a triangular prism is presented; focus is made on the second-order case. Space of functions for the prism is given. Basis functions are obtained as the dual basis with respect to suitably discretized Nédélec degrees of freedom functionals acting on elements of the space. Thus, the linear independence of the basis functions is assured while the belonging of the basis to the a priori given space of functions is guaranteed. Different strategies for the finite element assembly of the basis are discussed. Numerical results showing the verification procedure of the correctness of the implemented basis functions are given. Numerical results about sensibility of the condition number of the basis obtained concerning the quality of the elements of the mesh are also shown. Comparison with other representative sets of basis functions for prisms is included.},
  file = {C\:\\Users\\rial9_000\\Zotero\\storage\\4AIMZNCX\\7529074.html},
  html = {https://doi.org/10.1109/TAP.2016.2597640},
  jcr = {2.957 (2016)},
  jcrcat = {Q1, 61/262 (Engineering, Electrical and Electronic)},
  keywords = {computational electromagnetics,Curl-conforming element,Electromagnetic scattering,Electromagnetics,finite element analysis,Finite element analysis,finite element assembly,higher-order,linear independence,Microwave antennas,mixed-order curl-conforming basis functions,Nédélec,prism,second-order Nedelec curl-conforming prismatic element,Systematics,Tensile stress,triangular prism},
  number = {10},
  selected = {true}
}

@article{aamor_apm15,
  title = {Posidonia: {{A}} Tool for {{HPC}} and Remote Scientific Simulations [{{EM Programmer}}'s {{Notebook}}]},
  author = {Amor-Martin, Adrian and Martinez-Fernandez, Ignacio and Garcia-Castillo, Luis E.},
  date = {2015},
  journaltitle = {IEEE Antennas and Propagation Magazine},
  volume = {57},
  pages = {166--177},
  publisher = {{IEEE}},
  doi = {10.1109/MAP.2015.2481824},
  abstract = {This article presents a software tool named Posidonia. Posidonia removes the barrier to entry for the novice user of high-performance computing (HPC) systems, and remote scientific simulations in general, while increasing productivity of the experienced user. Posidonia manages communication with the remote computer system and interacts with its batch system (job scheduler). In addition, Posidonia keeps a history repository of simulations. The software also comes in several versions, including desktop, Android, and web interfaces; fully integration with given simulators/solvers has also been developed. We have designed an implementation within the paradigm of object orientation using Java and as a layered architecture that provides increased code reuse. In this article, we show the functionality, usability, and software architecture of Posidonia.},
  html = {https://doi.org/10.1109/MAP.2015.2481824},
  jcr = {0.896 (2015)},
  jcrcat = {Q3, 165/257 (Engineering, Electrical and Electronic)},
  number = {6}
}

@article{aamor_ijrmcae19,
  title = {Construction of Higher-Order Curl-Conforming Finite Elements and Its Assembly},
  author = {Amor-Martin, Adrian and Garcia-Castillo, Luis E.},
  date = {2019},
  journaltitle = {International Journal of RF and Microwave Computer-Aided Engineering},
  volume = {29},
  pages = {e21753},
  publisher = {{John Wiley \& Sons, Inc. Hoboken, USA}},
  doi = {10.1002/MMCE.21753},
  abstract = {Different choices are available when constructing vector finite element bases in real coordinates. In this communication, two different designs of higher‐order curl‐conforming basis functions are introduced and explained, showing the particularities of its assembly. Tetrahedra and hexahedra are used as element shapes to assess the effect of triangular and quadrilateral faces on the two considered constructions of basis functions. A comparison of their robustness in terms of the condition number of the finite element matrices for a number of distortions is included.},
  html = {https://doi.org/10.1002/MMCE.21753},
  jcr = {1.528 (2019)},
  jcrcat = {Q3, 184/266 (Engineering, Electrical and Electronic)},
  number = {8}
}

@article{aamor_ijrmcae20,
  title = {A Testbench of Arbitrary Accuracy for Electromagnetic Simulations},
