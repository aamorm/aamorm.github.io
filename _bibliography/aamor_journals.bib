  doi = {10.1002/MMCE.22342},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/mmce.22342},
  urldate = {2020-10-24},
  abstract = {Several electromagnetic problems for verification purposes in computational electromagnetics are introduced. Details about the formulation of a generalized eigenvalue problem for non-lossy and lossy materials are provided to obtain a fast and ready-to-use way of verification. Codes written using the symbolic toolbox from MATLAB are detailed to obtain an arbitrary accuracy for the proposed problems. Finally, numerical results in a finite element method code are presented together with the analytical values to show the accuracy of the code proposed.},
